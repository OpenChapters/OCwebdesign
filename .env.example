# Copy this file to .env and fill in values before starting the dev environment.
# Never commit .env to version control.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://ocweb:ocweb@db:5432/ocweb

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# GitHub token for chapter catalog sync (needs read:org + repo scopes)
GITHUB_TOKEN=

# SendGrid API key for PDF delivery emails
SENDGRID_API_KEY=

# S3 / file storage (leave blank to use local filesystem in dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
