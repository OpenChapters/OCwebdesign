% !TEX TS-program = arara
(# Jinja2 template for per-book HTML build via lwarp.            #)
(# Rendered by build_main_book_html_tex.py from build_request.json. #)
(# Images and merged bib are already prepared by the Celery task   #)
(# before arara runs — no copyImageFiles or mergemainbibfiles here. #)
% arara: clean: {files: ['main-authors.aux'] }
% arara: pdflatex: { shell: yes, interaction: batchmode }
% arara: makeindex: { style: StyleInd.ist, output: ind, log: ilg, input: idx }
% arara: biber
% arara: lwarpmk: { options: ['print'] }
% arara: lwarpmk: { options: ['printindex'] }
% arara: lwarpmk: { options: ['html'] }
% arara: lwarpmk: { options: ['html'] }
% arara: lwarpmk: { options: ['htmlindex'] }
% arara: lwarpmk: { options: ['html'] }
% arara: lwarpmk: { options: ['clean'] }
% arara: clean: { extensions: [aux, bbl, bcf, blg, idx, ilg, ind, log, ptc, toc]}
% arara: clean: { files: ['gitHeadLocal.gin', 'main.run.xml'] }
%
% Generated by OpenChapters web — per-book HTML build
% Book ID   : (( build_id ))
% Book date : (( build_date ))
% Book title: (( book_title ))

\documentclass[11pt,fleqn,A4paper]{book}

\usepackage{iftex}
\ifPDFTeX
\usepackage{lmodern}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\else
\usepackage{fontspec}
\fi

\usepackage[
 makeindex,
 ImagesDirectory=ImageFolder,
 HomeHTMLFilename=index,
 HTMLFilename={node-},
 latexmk,
 mathjax,
]{lwarp}

\usepackage{OpenChaptersHTML}
\usepackage{colortbl}  % \cellcolor, \rowcolor, \columncolor
\usepackage{arara}

% Override the git mark prefix for web HTML builds.
\renewcommand{\gitMarkPref}{[OpenChapters Web HTML Build]}

\setcounter{tocdepth}{2}
\setcounter{secnumdepth}{2}
% FileDepth=1 splits the output at chapter boundaries; parts are not
% split to their own file (the landing page shows the parts TOC).
\setcounter{FileDepth}{1}
\booltrue{CombineHigherDepths}
\boolfalse{FileSectionNames}
% Show parts + chapters + sections in the sidetoc for cross-chapter nav.
\setcounter{SideTOCDepth}{2}

\HTMLTitle{(( book_title ))}
\HTMLAuthor{(( book_author ))}
\HTMLLanguage{en-US}
\HTMLDescription{(( book_title ))}
\CSSFilename{lwarp_sagebrush.css}

% OpenChaptersHTML.sty defines \chaptergraphicspath as ImageFolder/.
% Leave \graphicspath empty so chapter-provided paths are not doubled.
\renewcommand{\graphicspath}{}
\newcommand{\isHTML}{Yes}
\newcommand{\isEPUB}{No}

% User-defined commands (HTML-safe variant)
\input{preambleHTML.ins}

% Merged bibliography (OpenChapters.bib produced by concat_bibs.py).
\addbibresource{OpenChapters.bib}

\begin{document}

% Emit a table of contents — lwarp uses this to populate the sidetoc
% navigation and the index.html landing page.
\tableofcontents

(% if has_frontmatter %)
\input{matter/Frontmatter}
(% endif %)

% Open the authors file for writing after Frontmatter is complete.
\immediate\openout\authorfile=\jobname-authors.aux%

% ================================================================
% Parts and chapters — generated from build_request.json
% ================================================================

(% for part in parts %)
% ----------------------------------------------------------------
\part{(( part.title ))}
% ----------------------------------------------------------------
(% for chapter in part.chapters %)
\include{(( chapter.include_path ))}
(% endfor %)

(% endfor %)
% ================================================================

(% if has_postmatter %)
\input{matter/Postmatter}
(% endif %)

\end{document}
