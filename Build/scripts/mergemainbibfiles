#!/usr/bin/env bash
# Wrapper installed at /usr/local/bin/mergemainbibfiles in the worker Docker image.
# The arara rule invokes:  bash -i -c 'mergemainbibfiles'
# arara runs with CWD = the temp build workspace (where main.tex lives).
#
# The Python scripts are installed at /opt/ocbuild/Build/scripts/ in the image
# (set via OCBUILD_SCRIPTS_DIR to override).
SCRIPTS_DIR="${OCBUILD_SCRIPTS_DIR:-/opt/ocbuild/Build/scripts}"
exec python3 "${SCRIPTS_DIR}/concat_bibs.py" --workdir "$(pwd)"
