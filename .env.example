# Copy this file to .env and fill in values before starting the dev environment.
# Never commit .env to version control.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://ocweb:ocweb@db:5432/ocweb

CELERY_BROKER_URL=amqp://ocweb:ocweb@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://

# GitHub token for chapter catalog sync (needs read:org + repo scopes)
GITHUB_TOKEN=

# SendGrid API key for PDF delivery emails (leave blank to skip email in dev)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@openchapters.org

# Site URL used in email links (frontend base URL)
SITE_URL=http://localhost:5173

# How many days PDF download links from emails remain valid
PDF_LINK_EXPIRY_DAYS=7
